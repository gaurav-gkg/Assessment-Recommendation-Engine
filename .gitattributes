# Normalize line endings to LF in the repo, CRLF on Windows checkout
* text=auto eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.env text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.toml text eol=lf

# Binaries – no line ending conversion
*.png binary
*.jpg binary
*.ico binary
*.index binary
*.pkl binary
